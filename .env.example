# Deployer wallet address (your Rabby wallet address)
DEPLOYER_ADDRESS=0xYourWalletAddressHere

# Sepolia RPC URL (get one free at https://alchemy.com or https://infura.io)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Etherscan API key for contract verification (get free at https://etherscan.io/myapikey)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
